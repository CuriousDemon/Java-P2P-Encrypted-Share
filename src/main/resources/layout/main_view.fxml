<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.himangshu.ui.MainController" prefWidth="400" prefHeight="300">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="SecureDrop-P2P" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <Label fx:id="statusLabel" text="Status: Ready" style="-fx-text-fill: gray;"/>

    <HBox alignment="CENTER" spacing="10">
        <Button text="Start Receiver" onAction="#handleStartReceiver" prefWidth="120"/>
        <Button text="Send File" onAction="#handleSendFile" prefWidth="120"/>
    </HBox>
</VBox>